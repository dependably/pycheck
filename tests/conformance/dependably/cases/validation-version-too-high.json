{
  "name": "validation-version-too-high",
  "description": "A version greater than supported is CONFIG_VERSION.",
  "tool": "npm-check",
  "files": {
    ".dependably": {
      "version": 99,
      "npm-check": {
        "failOn": {
          "count": 1
        }
      }
    }
  },
  "expect": {
    "error": "CONFIG_VERSION"
  }
}
